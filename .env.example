# =============================================================================
# Environment variables for slayer-trade.
# Copy to .env (server-side, gitignored) and/or .env.local (Vite client vars).
# Do NOT commit real secrets — this file documents names only.
# =============================================================================

# --- App ---
# APP_URL: Public base URL where this app is hosted. Used to build Stripe
# Checkout success/cancel redirect URLs. Defaults to http://localhost:3000.
APP_URL=

# --- Stripe (billing) ---
# STRIPE_SECRET_KEY: Stripe secret API key (sk_test_... / sk_live_...).
# When unset, billing endpoints respond 503 ("Payments are not configured yet.").
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET: Signing secret (whsec_...) for the /api/billing/webhook
# endpoint. Get it from the Stripe CLI (`stripe listen`) or the Dashboard webhook.
STRIPE_WEBHOOK_SECRET=
# VITE_STRIPE_PUBLISHABLE_KEY: Stripe publishable key (pk_test_... / pk_live_...).
# Exposed to the browser via Vite; safe to ship to the client.
VITE_STRIPE_PUBLISHABLE_KEY=

# --- Database (Postgres) ---
# Runtime connection (src/db/index.ts).
SQL_HOST=
SQL_USER=
SQL_PASSWORD=
SQL_DB_NAME=
# SQL_SSL: TLS for the DB connection (PII + password hashes + Stripe ids otherwise
# travel in cleartext). 'require'/'verify' = encrypt AND verify the server cert
# (strongest); 'no-verify'/'prefer' = encrypt without cert verification (managed/
# self-signed certs); unset/'disable' = no TLS (local dev). Set this in production.
SQL_SSL=
# Drizzle Kit migrations (src/db/drizzle.config.ts) use admin credentials:
# SQL_ADMIN_USER=
# SQL_ADMIN_PASSWORD=

# --- Optional market data providers ---
# Provider precedence: ThetaData -> Tradier -> Polygon -> sandbox.
#
# ThetaData v3 (preferred — one feed covers spot + chains/greeks/OI + candles).
# Set THETADATA_API_KEY (from your ThetaData portal) to activate. The key is sent
# as a Bearer header for the direct/cloud API; for a LOCAL Theta Terminal the key
# lives in the Terminal's own config and you only need THETADATA_BASE_URL here.
# THETADATA_API_KEY=
# THETADATA_BASE_URL=http://127.0.0.1:25503/v3
# THETADATA_ENABLED=true   # alternative activation when using a keyless local Terminal
#
# POLYGON_API_KEY=
# TRADIER_API_KEY=
# TRADIER_ENV=sandbox

# --- Server / security ---
# COOKIE_SECRET: HMAC secret for signing session cookies. MUST be set in
# production (else an ephemeral random one is generated and sessions drop on
# restart). On Render this is auto-generated via render.yaml.
COOKIE_SECRET=
# ADMIN_EMAILS: comma-separated emails granted admin access.
ADMIN_EMAILS=
# OWNER_EMAILS: comma-separated emails granted OWNER (superuser) access. Drives
# owner status entirely from env so it can be rotated without a code change — set
# this in production (e.g. OWNER_EMAILS=you@example.com).
OWNER_EMAILS=
# NODE_ENV: 'production' on a deployed host (serves the built frontend).
NODE_ENV=
# JSON_BODY_LIMIT: optional override for the JSON body size cap (default ~12mb).
# JSON_BODY_LIMIT=

# --- Dev-only escape hatches (leave UNSET in production) ---
# These guard sandbox auth + simulated billing and FAIL CLOSED: each endpoint is
# enabled ONLY when its flag === 'true', independent of NODE_ENV, so a
# misconfigured NODE_ENV can never expose them in production.
#   ALLOW_SANDBOX_AUTH=true  -> enables /api/auth/sandbox, /api/auth/callback, and
#                               clerk-login auto-provisioning/first-password (local dev only).
#   ALLOW_SIMULATED_BILLING=true -> enables /api/billing/process, which grants tiers
#                                  without Stripe. Use ONLY for local/staging keyless demos.
#                                  It is disabled by default in every environment.
# ALLOW_SANDBOX_AUTH=
# ALLOW_SIMULATED_BILLING=
