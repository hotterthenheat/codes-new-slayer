node_modules/
build/
dist/
coverage/
.DS_Store

# Local-only preview/scratch entry files (regenerable; never committed)
_*.tsx
_*.mjs
_*.cjs
*.log
.env*
!.env.example
# Keyless-mode user store (file-based fallback when SQL_HOST is unset). Never commit user data.
users-fallback.json
users-fallback.json*

# Local SQLite database (per-user tracked trades / backtesting). Never commit trade data.
# Anchored to the repo root so it only ignores the runtime DB folder, not source
# directories named "data" (e.g. src/pinpoint/data/ chart helpers).
/data/
*.db
*.db-journal
*.db-wal
*.db-shm
_*.html

# SciChart WASM copied from node_modules at build time (scripts/copy-scichart-wasm.mjs)
public/scichart/
